# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
dist/
out/
.turbo/
*.tsbuildinfo

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Brainstorming / superpowers state (per-session artifacts)
.superpowers/

# Processed photos (generated from data/cvs/photos/)
public/photos/*
!public/photos/.gitkeep

# Generated CV PDFs
*.pdf
!docs/**/*.pdf

# Visual regression test actual screenshots (ephemeral, baselines are committed)
**/__visual__/**/.actual/

# Showcase assets are synced from docs/screenshots/ at build time — no copies committed.
apps/showcase/screenshots/
# Showcase Tailwind output — generated by `pnpm --filter @codevena/cvmake-showcase build:css`.
apps/showcase/tailwind.css

# Personal / sensitive data — never commit (kept local only)
data/letters/
scripts/build-letter.mjs

# Personal CV data — gitignored. Copy data/cvs/example.*.yaml to data/cvs/cv.*.yaml
# and edit yours locally. Templates stay clean of forker data.
data/cvs/*.yaml
data/cvs/*.yml
!data/cvs/example.*.yaml
!data/cvs/example.*.yml
data/cvs/photos/*
!data/cvs/photos/example-*
!data/cvs/photos/.gitkeep
!data/cvs/photos/README.md

# Session/review artifacts — local-only, never public
NEXT_SESSION.md
LAUNCH_DRAFTS.md
audit.md
.review-logs/
.review/
.audit/
