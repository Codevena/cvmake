    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cvmake/schema": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-image-crop": "11.0.7"
  },
  "devDependencies": {
    "@testing-library/react": "16.0.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "happy-dom": "15.11.6",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
