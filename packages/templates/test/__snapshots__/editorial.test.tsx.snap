exports[`EditorialTemplate > matched HTML-Snapshot 1`] = `"<article class="editorial"><div class="editorial__page"><div class="editorial__hero"><img class="editorial__hero-img" src="/photos/markus.jpg" alt="Markus Wiesecke"/></div><header class="editorial__masthead"><h1 class="editorial__name">Markus Wiesecke</h1><div class="editorial__byline-block"><div class="editorial__title">Fullstack Developer</div><div class="editorial__contacts"><span class="editorial__contact-item">hello@codevena.dev</span><span class="editorial__contact-item">+49 175 9025586</span><span class="editorial__contact-item">Wuppertal, DE</span><span class="editorial__contact-item">https://codevena.dev</span><span class="editorial__contact-item">github.com/codevena</span><span class="editorial__contact-item">linkedin.com/in/markus-wiesecke</span></div></div></header><div class="editorial__body"><div class="editorial__summary-wrap"><h2 class="editorial__section-heading">Profil</h2><p class="editorial__summary-text">Fullstack Developer mit Fokus auf Next.js und TypeScript.</p></div><section class="editorial__section editorial__section--full"><h2 class="editorial__section-heading">Berufserfahrung</h2><div class="editorial__entry"><div class="editorial__entry-head"><div class="editorial__entry-byline">Fullstack Developer — Codevena</div><div class="editorial__entry-date">Jan. 2020 – heute</div></div><div class="editorial__entry-title">Codevena</div><div class="editorial__entry-location">Wuppertal</div><ul class="editorial__bullets"><li>Next.js 16 SaaS entwickelt</li><li>Hetzner + Coolify Deployment</li></ul></div></section><section class="editorial__section"><h2 class="editorial__section-heading">Ausbildung</h2><div class="editorial__entry"><div class="editorial__entry-head"><div class="editorial__entry-byline">Fachinformatiker Anwendungsentwicklung — BBQ Düsseldorf</div><div class="editorial__entry-date">Aug. 2024 – Juli 2026</div></div><div class="editorial__entry-title">BBQ Düsseldorf</div></div></section><section class="editorial__section"><h2 class="editorial__section-heading">Kenntnisse</h2><div class="editorial__skills-group"><div class="editorial__skills-group-label">Backend</div><div class="editorial__skills-items">Node.js · Prisma</div></div><div class="editorial__skills-group"><div class="editorial__skills-group-label">Frontend</div><div class="editorial__skills-items">React · Tailwind</div></div></section><section class="editorial__section"><h2 class="editorial__section-heading">Sprachen</h2><div class="editorial__lang-list"><div class="editorial__lang-item"><span>Deutsch</span><span class="editorial__lang-level">native</span></div><div class="editorial__lang-item"><span>Englisch</span><span class="editorial__lang-level">B2</span></div></div></section><section class="editorial__section"><h2 class="editorial__section-heading">Projekte</h2><div class="editorial__custom-entry"><div class="editorial__custom-title">FlashBuddy</div><div class="editorial__custom-subtitle">SaaS</div><p class="editorial__custom-desc">Lern-Karten App.</p></div></section></div></div></article>"`;
