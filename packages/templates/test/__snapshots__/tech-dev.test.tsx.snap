exports[`TechDevTemplate > matched HTML-Snapshot 1`] = `"<article class="tech-dev"><div class="tech-dev__page"><aside class="tech-dev__sidebar"><img class="tech-dev__photo" src="photos/alex.jpg" alt="Alex Schmidt"/><section class="tech-dev__sidebar-section"><h2>// contact</h2><ul class="tech-dev__contact-list"><li><span class="tech-dev__contact-key">email: </span><span class="tech-dev__contact-val">hello@codevena.dev</span></li><li><span class="tech-dev__contact-key">phone: </span><span class="tech-dev__contact-val">+49 30 0000000</span></li><li><span class="tech-dev__contact-key">location: </span><span class="tech-dev__contact-val">Berlin, DE</span></li><li><span class="tech-dev__contact-key">web: </span><span class="tech-dev__contact-val">codevena.dev</span></li><li><span class="tech-dev__contact-key">github: </span><span class="tech-dev__contact-val">codevena</span></li><li><span class="tech-dev__contact-key">linkedin: </span><span class="tech-dev__contact-val">alex-schmidt</span></li></ul></section><section class="tech-dev__sidebar-section"><h2>// skills</h2><div class="tech-dev__skills-group"><span class="tech-dev__skills-group-name">Backend</span><span class="tech-dev__skills-array">[Node.js, Prisma]</span></div><div class="tech-dev__skills-group"><span class="tech-dev__skills-group-name">Frontend</span><span class="tech-dev__skills-array">[React, Tailwind]</span></div></section><section class="tech-dev__sidebar-section"><h2>// languages</h2><ul class="tech-dev__lang-list"><li>Deutsch<span class="tech-dev__lang-sep">//</span><span class="tech-dev__lang-level">native</span></li><li>Englisch<span class="tech-dev__lang-sep">//</span><span class="tech-dev__lang-level">B2</span></li></ul></section></aside><main class="tech-dev__main"><p class="tech-dev__terminal-prompt">&gt; alex@codevena:~$ whoami</p><header><h1 class="tech-dev__name">Alex Schmidt</h1><p class="tech-dev__title">Fullstack Developer</p></header><section class="tech-dev__section"><h2 class="tech-dev__section-heading">// profil</h2><p class="tech-dev__summary">Fullstack Developer mit Fokus auf Next.js und TypeScript.</p></section><section class="tech-dev__section"><h2 class="tech-dev__section-heading">// berufserfahrung</h2><div class="tech-dev__entry"><div class="tech-dev__entry-head"><div class="tech-dev__entry-title-row"><span class="tech-dev__entry-company-tag">#codevena</span><span class="tech-dev__entry-role">Fullstack Developer</span></div><div class="tech-dev__entry-date">Jan. 2020 – heute</div></div><div class="tech-dev__entry-location">Berlin</div><ul class="tech-dev__bullets"><li>Next.js 16 SaaS entwickelt</li><li>Hetzner + Coolify Deployment</li></ul><div class="tech-dev__entry-tags">[Next.js, TypeScript, PostgreSQL]</div></div></section><section class="tech-dev__section"><h2 class="tech-dev__section-heading">// ausbildung</h2><div class="tech-dev__entry"><div class="tech-dev__edu-head"><div class="tech-dev__edu-degree">Fachinformatiker Anwendungsentwicklung</div><div class="tech-dev__entry-date">Aug. 2024 – Juli 2026</div></div><div class="tech-dev__edu-institution">BBQ Düsseldorf</div></div></section><section class="tech-dev__section"><h2 class="tech-dev__section-heading">// projekte</h2><div class="tech-dev__custom-entry"><div class="tech-dev__custom-title">FlashBuddy</div><div class="tech-dev__custom-subtitle">SaaS</div><p class="tech-dev__custom-desc">Lern-Karten App.</p></div></section></main></div></article>"`;
