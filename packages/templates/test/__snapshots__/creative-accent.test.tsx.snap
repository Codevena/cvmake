exports[`CreativeAccentTemplate > matched HTML-Snapshot 1`] = `"<article class="creative-accent"><div class="creative-accent__page"><main class="creative-accent__main"><header class="creative-accent__header"><h1 class="creative-accent__name">Alex Schmidt</h1><p class="creative-accent__job-title">Fullstack Developer</p></header><section class="creative-accent__section"><h2 class="creative-accent__section-heading">Profil</h2><p class="creative-accent__summary-text">Fullstack Developer mit Fokus auf Next.js und TypeScript.</p></section><section class="creative-accent__section"><h2 class="creative-accent__section-heading">Berufserfahrung</h2><div class="creative-accent__entry"><div class="creative-accent__entry-head"><div class="creative-accent__entry-title">Fullstack Developer · Codevena</div><div class="creative-accent__entry-date">Jan. 2020 – heute</div></div><div class="creative-accent__entry-subtitle">Berlin</div><ul class="creative-accent__bullets"><li>Next.js 16 SaaS entwickelt</li><li>Hetzner + Coolify Deployment</li></ul><div class="creative-accent__entry-tags"><span class="creative-accent__pill">Next.js</span><span class="creative-accent__pill">TypeScript</span><span class="creative-accent__pill">PostgreSQL</span></div></div></section><section class="creative-accent__section"><h2 class="creative-accent__section-heading">Ausbildung</h2><div class="creative-accent__entry"><div class="creative-accent__entry-head"><div class="creative-accent__entry-title">Fachinformatiker Anwendungsentwicklung · BBQ Düsseldorf</div><div class="creative-accent__entry-date">Aug. 2024 – Juli 2026</div></div></div></section><section class="creative-accent__section"><h2 class="creative-accent__section-heading">Kenntnisse</h2><div class="creative-accent__tag-group"><div class="creative-accent__tag-group-name">Backend</div><div class="creative-accent__tags"><span class="creative-accent__pill">Node.js</span><span class="creative-accent__pill">Prisma</span></div></div><div class="creative-